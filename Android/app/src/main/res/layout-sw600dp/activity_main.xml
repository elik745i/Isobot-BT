<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/top_bar_background"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="12dp"
        android:paddingRight="8dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/connectionIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/connection_indicator_background" />

            <TextView
                android:id="@+id/connectionStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/connection_state_idle"
                android:textColor="@color/ink"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="@color/ink" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle"
            android:textColor="@color/ink_muted"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/status_background"
            android:padding="14dp"
            android:text="@string/hero_copy"
            android:textColor="@color/ink"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/model_preview"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/model_preview_hint"
                android:textColor="@color/ink_muted"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/status_background">

                <android.webkit.WebView
                    android:id="@+id/modelPreviewWebView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_status"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/status_background"
                android:padding="12dp"
                android:text="@string/status_idle"
                android:textColor="@color/ink"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/quickSectionToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/section_expand"
                android:gravity="start|center_vertical"
                android:text="@string/section_quick_controls"
                android:textAllCaps="false" />

            <LinearLayout
                android:id="@+id/quickSectionContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="6"
                    android:useDefaultMargins="true">

                    <Button android:id="@+id/quickForward" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickBackward" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickSideRight" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickSideLeft" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickForwardLeft" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickForwardRight" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickBackwardLeft" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickBackwardRight" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickForwardClockwise" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickForwardCounter" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickBackwardClockwise" style="@style/Widget.Isobot.QuickButton" />
                    <Button android:id="@+id/quickBackwardCounter" style="@style/Widget.Isobot.QuickButton" />
                </GridLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/remoteSectionToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/section_expand"
                android:gravity="start|center_vertical"
                android:text="@string/section_remote_mode"
                android:textAllCaps="false" />

            <LinearLayout
                android:id="@+id/remoteSectionContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/remoteModeHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/remote_mode_hint"
                    android:textColor="@color/ink_muted"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/remote_pad_title"
                    android:textColor="@color/ink"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/remoteUpButton"
                        android:layout_width="88dp"
                        android:layout_height="56dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/remote_up"
                        android:textAllCaps="false"
                        android:textSize="22sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/remoteLeftButton"
                            android:layout_width="88dp"
                            android:layout_height="56dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/remote_left"
                            android:textAllCaps="false"
                            android:textSize="22sp" />

                        <Space
                            android:layout_width="18dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/remoteRightButton"
                            android:layout_width="88dp"
                            android:layout_height="56dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/remote_right"
                            android:textAllCaps="false"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/remoteDownButton"
                        android:layout_width="88dp"
                        android:layout_height="56dp"
                        android:layout_marginTop="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/remote_down"
                        android:textAllCaps="false"
                        android:textSize="22sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/remote_head_title"
                    android:textColor="@color/ink"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/remoteHeadLeftButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_head_left" />

                    <Button
                        android:id="@+id/remoteHeadRightButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_head_right" />
                </GridLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/remote_body_title"
                    android:textColor="@color/ink"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/remoteLeanForwardButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_lean_forward" />

                    <Button
                        android:id="@+id/remoteLeanBackButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_lean_back" />
                </GridLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/remote_arms_title"
                    android:textColor="@color/ink"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/remoteLeftArmButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_left_punch" />

                    <Button
                        android:id="@+id/remoteRightArmButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_right_punch" />

                    <Button
                        android:id="@+id/remoteLeftGuardButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_left_guard" />

                    <Button
                        android:id="@+id/remoteRightGuardButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_right_guard" />
                </GridLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/remote_legs_title"
                    android:textColor="@color/ink"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/remoteLeftLegButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_left_kick" />

                    <Button
                        android:id="@+id/remoteRightLegButton"
                        style="@style/Widget.Isobot.QuickButton"
                        android:text="@string/remote_right_kick" />
                </GridLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/catalogSectionToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/section_expand"
                android:gravity="start|center_vertical"
                android:text="@string/section_command_catalog"
                android:textAllCaps="false" />

            <LinearLayout
                android:id="@+id/catalogSectionContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/commandCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/command_count_background"
                    android:paddingLeft="10dp"
                    android:paddingTop="6dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/ink"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/search_hint"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/searchField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filterAll"
                            style="@style/Widget.Isobot.FilterButton"
                            android:checkable="true"
                            android:text="@string/filter_all" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filterMovement"
                            style="@style/Widget.Isobot.FilterButton"
                            android:layout_marginStart="8dp"
                            android:checkable="true"
                            android:text="@string/filter_movement" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filterCombat"
                            style="@style/Widget.Isobot.FilterButton"
                            android:layout_marginStart="8dp"
                            android:checkable="true"
                            android:text="@string/filter_combat" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filterSocial"
                            style="@style/Widget.Isobot.FilterButton"
                            android:layout_marginStart="8dp"
                            android:checkable="true"
                            android:text="@string/filter_social" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filterShowcase"
                            style="@style/Widget.Isobot.FilterButton"
                            android:layout_marginStart="8dp"
                            android:checkable="true"
                            android:text="@string/filter_showcase" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/emptyCommandsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/no_matching_commands"
                    android:textColor="@color/ink_muted"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/commandRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    </ScrollView>
</LinearLayout>
