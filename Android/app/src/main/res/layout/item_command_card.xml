<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/command_card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/commandIndex"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/command_index_background"
        android:gravity="center"
        android:textColor="@color/panel"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/commandName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/commandDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ink_muted"
            android:textSize="13sp" />
    </LinearLayout>

    <Button
        android:id="@+id/sendCommandButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/send" />
</LinearLayout>